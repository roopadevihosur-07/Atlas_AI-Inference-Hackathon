# ATLAS configuration

# ── Akamai AI Inference Cloud ─────────────────────────────────────
# OpenAI-compatible endpoint. The workshop will give you the exact base URL
# and the model name available to you.
AKAMAI_BASE_URL=https://api.akamai-inference.example/v1
AKAMAI_API_KEY=your_akamai_key_here
AKAMAI_MODEL=llama-3.3-70b-instruct

# ── Magnific (Freepik) ────────────────────────────────────────────
# Get a key at https://magnific.ai/api or https://www.freepik.com/api
MAGNIFIC_BASE_URL=https://api.freepik.com/v1
MAGNIFIC_API_KEY=your_magnific_key_here

# Text-to-image model endpoint (path after /ai/text-to-image/)
# Options: flux-dev, flux-schnell, mystic, classic-fast, etc.
MAGNIFIC_T2I_MODEL=flux-dev

# Upscaler creativity level (0-10). Higher = more invention, lower = faithful.
MAGNIFIC_UPSCALE_CREATIVITY=4
MAGNIFIC_UPSCALE_FACTOR=2

# ── Cost controls (turn on during dev!) ───────────────────────────
# MOCK_IMAGES=true → skip Magnific entirely, use picsum placeholders.
#                    Burns zero Magnific credits. Use this for UI/prompt iteration.
MOCK_IMAGES=false

# SKIP_UPSCALE=true → run text-to-image but skip the upscaler step.
#                     Cuts Magnific credit cost roughly in half per cell.
SKIP_UPSCALE=false

# ── Server ────────────────────────────────────────────────────────
PORT=8080

# Max concurrent Magnific calls. Bump up if your plan allows.
MAX_PARALLEL_CELLS=4
